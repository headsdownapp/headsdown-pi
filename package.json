{
  "name": "headsdown-pi",
  "version": "0.1.0",
  "description": "HeadsDown availability skill and extension for Pi agent. Gives Pi awareness of your focus mode, schedule, and availability before starting tasks.",
  "type": "module",
  "keywords": ["pi-package", "headsdown", "availability", "focus", "ai-agent"],
  "files": ["extensions", "skills", "README.md", "LICENSE"],
  "scripts": {
    "build": "echo 'No build needed. Extensions are loaded directly by Pi via jiti.'",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "prettier --check 'extensions/**/*.ts' 'test/**/*.ts'",
    "format": "prettier --write 'extensions/**/*.ts' 'test/**/*.ts'",
    "typecheck": "tsc --noEmit"
  },
  "pi": {
    "extensions": ["./extensions"],
    "skills": ["./skills"]
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/headsdownapp/headsdown-pi.git"
  },
  "homepage": "https://github.com/headsdownapp/headsdown-pi#readme",
  "bugs": {
    "url": "https://github.com/headsdownapp/headsdown-pi/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@headsdown/sdk": "^0.1.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-ai": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-ai": "*",
    "@sinclair/typebox": "*",
    "@types/node": "^20.17.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
